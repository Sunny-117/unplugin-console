{
  "name": "unplugin-console",
  "type": "module",
  "version": "0.0.8",
  "packageManager": "pnpm@10.11.0",
  "description": "A cross-bundler plugin that forwards browser console.log / info / warn / error to your dev-server terminal in real time.",
  "license": "MIT",
  "homepage": "https://github.com/Sunny-117/unplugin-console#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunny-117/unplugin-console.git"
  },
  "bugs": {
    "url": "https://github.com/Sunny-117/unplugin-console/issues"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "transform"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.cjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown -w",
    "lint": "eslint .",
    "play": "npm -C playground/vite run dev",
    "play:vite": "npm -C playground/vite run dev",
    "play:rspack": "npm -C playground/rspack run dev",
    "play:webpack": "npm -C playground/webpack run dev",
    "prepublishOnly": "npm run build",
    "release": "bumpp && pnpm publish",
    "start": "tsx src/index.ts",
    "test": "vitest"
  },
  "peerDependencies": {
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "nodemon": "^3.1.14",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "webpack": "^5.105.4"
  }
}
